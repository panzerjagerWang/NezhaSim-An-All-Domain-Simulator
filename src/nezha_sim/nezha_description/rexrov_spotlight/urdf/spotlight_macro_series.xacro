<?xml version="1.0"?>
<robot name="underwater_spotlight_gimbal_macro" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:macro name="spotlight_gimbal" params="
      parent_link
      prefix:=''
      ns:='/spotlight'
      mount_xyz:='0 0 0'
      mount_rpy:='0 0 0'
      use_ignition:='false'
      unique_id:=''">

    <material name="${prefix}Grey"><color rgba="0.6 0.6 0.6 1.0"/></material>
    <material name="${prefix}DarkGrey"><color rgba="0.3 0.3 0.3 1.0"/></material>
    
    <!-- 为每个圆柱体分别定义白色发光材质 - 添加透明度，减小半径差距 -->
    <material name="${prefix}BrightGlow1"><color rgba="1.0 1.0 1.0 0.7"/></material>
    <material name="${prefix}BrightGlow2"><color rgba="1.0 1.0 1.0 0.65"/></material>
    <material name="${prefix}BrightGlow3"><color rgba="1.0 1.0 1.0 0.6"/></material>
    <material name="${prefix}BrightGlow4"><color rgba="1.0 1.0 1.0 0.55"/></material>
    <material name="${prefix}BrightGlow5"><color rgba="1.0 1.0 1.0 0.5"/></material>

    <link name="${prefix}base_link">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="1.0"/>
        <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
      </inertial>
      <visual>
        <origin xyz="0 0 0.1" rpy="0 0 0"/>
        <geometry><cylinder radius="0.3" length="0.2"/></geometry>
        <material name="${prefix}Grey"/>
      </visual>
      <collision>
        <origin xyz="0 0 0.1" rpy="0 0 0"/>
        <geometry><cylinder radius="0.3" length="0.2"/></geometry>
      </collision>
    </link>

    <joint name="${prefix}mount_joint" type="fixed">
      <parent link="${parent_link}"/>
      <child link="${prefix}base_link"/>
      <origin xyz="${mount_xyz}" rpy="${mount_rpy}"/>
    </joint>

    <link name="${prefix}yaw_link">
      <inertial>
        <origin xyz="0 0 0.2" rpy="0 0 0"/>
        <mass value="0.5"/>
        <inertia ixx="0.005" ixy="0" ixz="0" iyy="0.005" iyz="0" izz="0.005"/>
      </inertial>
      <visual>
        <origin xyz="0 0 0.2" rpy="0 0 0"/>
        <geometry><cylinder radius="0.28" length="0.06"/></geometry>
        <material name="${prefix}DarkGrey"/>
      </visual>
      <collision>
        <origin xyz="0 0 0.2" rpy="0 0 0"/>
        <geometry><cylinder radius="0.28" length="0.06"/></geometry>
      </collision>
    </link>

    <link name="${prefix}pitch_link">
      <inertial>
        <origin xyz="0 0 0.26" rpy="0 0 0"/>
        <mass value="0.3"/>
        <inertia ixx="0.003" ixy="0" ixz="0" iyy="0.003" iyz="0" izz="0.003"/>
      </inertial>
      <visual>
        <origin xyz="0 0 0.26" rpy="0 0 0"/>
        <geometry><box size="0.06 0.5 0.06"/></geometry>
        <material name="${prefix}Grey"/>
      </visual>
      <collision>
        <origin xyz="0 0 0.26" rpy="0 0 0"/>
        <geometry><box size="0.06 0.5 0.06"/></geometry>
      </collision>
    </link>

    <!-- 分别创建5个独立的圆柱体link - 减小半径差距，更平滑过渡 -->
    <link name="${prefix}cylinder1_link">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="0.1"/>
        <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry><cylinder radius="0.18" length="1.0"/></geometry>
        <material name="${prefix}BrightGlow1"/>
      </visual>
    </link>

    <link name="${prefix}cylinder2_link">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="0.1"/>
        <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry><cylinder radius="0.25" length="1.0"/></geometry>
        <material name="${prefix}BrightGlow2"/>
      </visual>
    </link>

    <link name="${prefix}cylinder3_link">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="0.1"/>
        <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry><cylinder radius="0.32" length="1.0"/></geometry>
        <material name="${prefix}BrightGlow3"/>
      </visual>
    </link>

    <link name="${prefix}cylinder4_link">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="0.1"/>
        <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry><cylinder radius="0.39" length="1.0"/></geometry>
        <material name="${prefix}BrightGlow4"/>
      </visual>
    </link>

    <link name="${prefix}cylinder5_link">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="0.1"/>
        <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry><cylinder radius="0.46" length="1.0"/></geometry>
        <material name="${prefix}BrightGlow5"/>
      </visual>
    </link>

    <!-- 主聚光灯link，用于碰撞检测和光源 -->
    <link name="${prefix}spotlight_link">
      <inertial>
        <origin xyz="0 0 2.76" rpy="0 0 0"/>
        <mass value="1.0"/>
        <inertia ixx="0.02" ixy="0" ixz="0" iyy="0.02" iyz="0" izz="0.02"/>
      </inertial>
      <!-- 碰撞检测：使用简化的单个圆柱体 -->
      <collision>
        <origin xyz="0 0 2.76" rpy="0 0 0"/>
        <geometry><cylinder radius="0.35" length="5.0"/></geometry>
      </collision>
    </link>

    <!-- 将所有圆柱体连接到pitch_link -->
    <joint name="${prefix}pitch_to_cylinder1" type="fixed">
      <parent link="${prefix}pitch_link"/>
      <child link="${prefix}cylinder1_link"/>
      <origin xyz="0 0 0.76" rpy="0 0 0"/>
    </joint>

    <joint name="${prefix}pitch_to_cylinder2" type="fixed">
      <parent link="${prefix}pitch_link"/>
      <child link="${prefix}cylinder2_link"/>
      <origin xyz="0 0 1.76" rpy="0 0 0"/>
    </joint>

    <joint name="${prefix}pitch_to_cylinder3" type="fixed">
      <parent link="${prefix}pitch_link"/>
      <child link="${prefix}cylinder3_link"/>
      <origin xyz="0 0 2.76" rpy="0 0 0"/>
    </joint>

    <joint name="${prefix}pitch_to_cylinder4" type="fixed">
      <parent link="${prefix}pitch_link"/>
      <child link="${prefix}cylinder4_link"/>
      <origin xyz="0 0 3.76" rpy="0 0 0"/>
    </joint>

    <joint name="${prefix}pitch_to_cylinder5" type="fixed">
      <parent link="${prefix}pitch_link"/>
      <child link="${prefix}cylinder5_link"/>
      <origin xyz="0 0 4.76" rpy="0 0 0"/>
    </joint>

    <joint name="${prefix}pitch_to_spotlight" type="fixed">
      <parent link="${prefix}pitch_link"/>
      <child link="${prefix}spotlight_link"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>

    <!-- 为每个圆柱体分别设置Gazebo材质 - 使用发光材质 -->
    <gazebo reference="${prefix}cylinder1_link">
      <material>Gazebo/WhiteGlow</material>
      <self_collide>false</self_collide>
    </gazebo>

    <gazebo reference="${prefix}cylinder2_link">
      <material>Gazebo/WhiteGlow</material>
      <self_collide>false</self_collide>
    </gazebo>

    <gazebo reference="${prefix}cylinder3_link">
      <material>Gazebo/WhiteGlow</material>
      <self_collide>false</self_collide>
    </gazebo>

    <gazebo reference="${prefix}cylinder4_link">
      <material>Gazebo/WhiteGlow</material>
      <self_collide>false</self_collide>
    </gazebo>

    <gazebo reference="${prefix}cylinder5_link">
      <material>Gazebo/WhiteGlow</material>
      <self_collide>false</self_collide>
    </gazebo>

    <!-- 聚光灯光源 -->
    <gazebo reference="${prefix}spotlight_link">
      <light name="${prefix}spotlight_beam${unique_id}" type="spot">
        <pose>0 0 0.35 0 0 0</pose>
        <diffuse>1.2 1.2 1.2 1</diffuse>
        <specular>0.5 0.5 0.5 1</specular>
        <attenuation>
          <range>70</range>
          <constant>0.45</constant>
          <linear>0.02</linear>
          <quadratic>0.0008</quadratic>
        </attenuation>
        <direction>0 0 1</direction>
        <spot>
          <inner_angle>0.45</inner_angle>
          <outer_angle>1.05</outer_angle>
          <falloff>0.4</falloff>
        </spot>
        <cast_shadows>true</cast_shadows>
      </light>
    </gazebo>

    <!-- joints -->
    <joint name="${prefix}base_yaw_joint" type="revolute">
      <parent link="${prefix}base_link"/>
      <child link="${prefix}yaw_link"/>
      <origin xyz="0 0 0.2" rpy="0 0 0"/>
      <axis xyz="0 0 1"/>
      <limit lower="-3.14159" upper="3.14159" effort="10" velocity="2.0"/>
      <dynamics damping="0.1" friction="0.0"/>
    </joint>

    <joint name="${prefix}head_pitch_joint" type="revolute">
      <parent link="${prefix}yaw_link"/>
      <child link="${prefix}pitch_link"/>
      <origin xyz="0 0 0.06" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit lower="-1.2" upper="1.2" effort="10" velocity="2.0"/>
      <dynamics damping="0.1" friction="0.0"/>
    </joint>

    <gazebo>
      <plugin name="${prefix}gazebo_ros_control" filename="libgazebo_ros_control.so">
        <robotNamespace>${ns}</robotNamespace>
      </plugin>
    </gazebo>

    <transmission name="${prefix}base_yaw_trans">
      <type>transmission_interface/SimpleTransmission</type>
      <joint name="${prefix}base_yaw_joint">
        <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
      </joint>
      <actuator name="${prefix}base_yaw_motor">
        <mechanicalReduction>1</mechanicalReduction>
      </actuator>
    </transmission>

    <transmission name="${prefix}head_pitch_trans">
      <type>transmission_interface/SimpleTransmission</type>
      <joint name="${prefix}head_pitch_joint">
        <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
      </joint>
      <actuator name="${prefix}head_pitch_motor">
        <mechanicalReduction>1</mechanicalReduction>
      </actuator>
    </transmission>

    <gazebo reference="${prefix}base_link"><material>Gazebo/Grey</material></gazebo>
    <gazebo reference="${prefix}yaw_link"><material>Gazebo/DarkGrey</material></gazebo>
    <gazebo reference="${prefix}pitch_link"><material>Gazebo/Grey</material></gazebo>

  </xacro:macro>
</robot>



