<launch>
  <arg name="use_gui" default="true"/>
  <arg name="world_name" default="$(find gazebo_ros)/worlds/empty.world"/>

  <include file="$(find gazebo_ros)/launch/empty_world.launch">
    <arg name="world_name" value="$(arg world_name)"/>
    <arg name="use_sim_time" value="true"/>
    <arg name="gui" value="$(arg use_gui)"/>
  </include>

  <param name="robot_description" command="$(find xacro)/xacro '$(find nezha_description)/spotlight/urdf/spotlight.xacro' use_ignition:=false"/>

  <node pkg="gazebo_ros" type="spawn_model" name="spawn_spotlight"
        args="-urdf -param robot_description -model spotlight -z 0.01"/>

  <rosparam file="$(find nezha_description)/spotlight/config/spotlight_controllers.yaml" command="load"/>

  <group ns="spotlight">
    <node name="controller_spawner" pkg="controller_manager" type="spawner"
          args="joint_state_controller base_yaw_position head_pitch_position"/>
  </group>
</launch>

