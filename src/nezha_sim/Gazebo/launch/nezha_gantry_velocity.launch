<?xml version="1.0"?>
<launch>
  <!-- ==================== 通用参数 ==================== -->
  <arg name="rack_name" default="nezha_gantry"/>
  <arg name="namespace" default="nezha_rocket"/>
  <arg name="paused" default="false"/>  <!-- 改为 false -->
  <arg name="use_sim_time" default="false"/>  <!-- 改为 false -->
  <arg name="gui" default="true"/>
  <arg name="headless" default="false"/>
  <arg name="debug" default="false"/>
  <arg name="verbose" default="false"/>
  <arg name="world_name" default="nezha_lake"/>
  
  <!-- ==================== UAV 相关参数 ==================== -->
  <arg name="enable_mavlink_interface" default="false"/>
  <arg name="uav_log_file" default="$(arg namespace)"/>
  <arg name="wait_to_record_bag" default="false"/>
  <arg name="uav_enable_logging" default="false"/>
  <arg name="uav_enable_ground_truth" default="true"/>  <!-- 改为 true -->

  <!-- ==================== 环境变量设置 ==================== -->
  <env name="GAZEBO_MODEL_PATH" value="${GAZEBO_MODEL_PATH}:$(find rotors_gazebo)/models:$(find nezha_gazebo)/models"/>
  <env name="GAZEBO_RESOURCE_PATH" value="${GAZEBO_RESOURCE_PATH}:$(find rotors_gazebo)/models"/>

  <!-- ==================== 1. 启动 Gazebo ==================== -->
  <include file="$(find gazebo_ros)/launch/empty_world.launch">
    <arg name="world_name" value="$(find nezha_gazebo)/worlds/$(arg world_name).world"/>
    <arg name="debug" value="$(arg debug)"/>
    <arg name="gui" value="$(arg gui)"/>
    <arg name="paused" value="$(arg paused)"/>
    <arg name="use_sim_time" value="$(arg use_sim_time)"/>
    <arg name="headless" value="$(arg headless)"/>
    <arg name="verbose" value="$(arg verbose)"/>
  </include>

  <!-- ==================== 2. 添加必要的辅助节点 ==================== -->
  <include file="$(find uuv_assistants)/launch/publish_world_ned_frame.launch"/>
  
  <node name="publish_world_models"
        pkg="uuv_assistants"
        type="publish_world_models.py"
        output="screen">
    <rosparam subst_value="true">
      meshes:
        lake:
          mesh: package://uuv_gazebo_worlds/models/lake/meshes/LakeBottom.dae
          model: lake
    </rosparam>
  </node>

  <!-- ==================== 3. 龙门架部分 ==================== -->
  <group ns="gantry">
    <!-- 加载龙门架 URDF -->
    <param name="robot_description"
           command="$(find xacro)/xacro '$(find nezha_description)/$(arg rack_name)_velocity/nezha_gantry.xacro'"/>

    <!-- 发布龙门架状态 -->
    <node name="robot_state_publisher"
          pkg="robot_state_publisher"
          type="robot_state_publisher"
          output="screen">
      <param name="publish_frequency" value="50.0"/>
    </node>

    <!-- 生成龙门架模型 -->
    <node name="spawn_gantry"
          pkg="gazebo_ros"
          type="spawn_model"
          args="-urdf -param robot_description -model nezha_gantry -z 0.05"
          respawn="false"
          output="screen"/>

    <!-- 龙门架控制器 -->
    <rosparam file="$(find nezha_description)/$(arg rack_name)_velocity/config/gantry_control.yaml"
              command="load"/>
    <node name="controller_spawner"
          pkg="controller_manager"
          type="spawner"
          respawn="false"
          output="screen"
          args="joint_state_controller
                vertical_velocity_controller
                horizontal_velocity_controller
                left_finger_velocity_controller
                right_finger_velocity_controller"/>
    <param name="control_mode" value="velocity"/>
  </group>

  <node name="attach_after_spawn" pkg="nezha_gazebo" type="attach_after_spawn.py" output="screen"/>

  <!-- ==================== 4. UAV 启动 ==================== -->
  <!-- 添加 TF 变换 -->
  <include file="$(find uuv_assistants)/launch/message_to_tf.launch">
    <arg name="namespace" value="$(arg namespace)"/>
    <arg name="world_frame" value="world"/>
    <arg name="child_frame_id" value="/$(arg namespace)/base_link"/>
  </include>

  <group ns="$(arg namespace)">
    <include file="$(find nezha_gazebo)/launch/spawn_mav_motified.launch">
      <arg name="mav_name" value="$(arg namespace)"/>
      <arg name="namespace" value="$(arg namespace)"/>
      <arg name="model" value="$(find nezha_description)/$(arg namespace)/config/mav_generic_odometry_sensor.gazebo"/>

      <arg name="enable_logging" value="$(arg uav_enable_logging)"/>
      <arg name="enable_ground_truth" value="$(arg uav_enable_ground_truth)"/>
      <arg name="log_file" value="$(arg uav_log_file)"/>
      <arg name="wait_to_record_bag" value="$(arg wait_to_record_bag)"/>
      <arg name="enable_mavlink_interface" value="$(arg enable_mavlink_interface)"/>

      <arg name="x" value="0.0"/>
      <arg name="y" value="0.0"/>
      <arg name="z" value="1.9"/>
    </include>

    <!-- UAV 控制器 -->
    <node name="lee_position_controller_node" 
          pkg="rotors_control" 
          type="lee_position_controller_node" 
          output="screen">
      <rosparam command="load" file="$(find nezha_description)/$(arg namespace)/config/lee_controller_$(arg namespace).yaml"/>
      <rosparam command="load" file="$(find nezha_description)/$(arg namespace)/config/$(arg namespace).yaml"/>
      <remap from="odometry" to="odometry_sensor1/odometry"/>
    </node>

    <!-- 移除 hovering_example,如果不需要的话 -->
    <!-- <node name="hovering_example" 
          pkg="rotors_gazebo" 
          type="hovering_example" 
          output="screen"/> -->

    <!-- UAV 状态发布器 -->
    <node name="robot_state_publisher" 
          pkg="robot_state_publisher" 
          type="robot_state_publisher" 
          output="screen"/>
  </group>

  <!-- ==================== 5. 键盘控制 ==================== -->
  <node name="gantry_velocity_teleop"
        pkg="nezha_gazebo"
        type="gantry_controller.py"
        output="screen"/>

</launch>



